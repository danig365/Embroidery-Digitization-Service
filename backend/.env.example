# Django Settings
SECRET_KEY=your-random-secret-key-here-GENERATE-NEW-ONE-FOR-PRODUCTION
# DEBUG defaults to False for production safety
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost,127.0.0.1
FRONTEND_URL=https://yourdomain.com

# CORS Configuration - Frontend origins allowed to make requests
# Comma-separated list of allowed origins (defaults to FRONTEND_URL)
# Examples: https://yourdomain.com,https://www.yourdomain.com,http://localhost:3000
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,http://localhost:3000

# Database Configuration - PostgreSQL required for production
# DO NOT use SQLite in production
DB_ENGINE=django.db.backends.postgresql
DB_NAME=embroidery_db
DB_USER=embroidery_user
DB_PASSWORD=your-secure-db-password-here
DB_HOST=localhost
DB_PORT=5432

# Security Settings - Enable for production with HTTPS
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Email Configuration - Required for password reset and notifications
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-or-smtp-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# OpenAI API Configuration
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
OPENAI_MODEL=gpt-image-1-mini

# Stripe Payment Configuration
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key-here
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
